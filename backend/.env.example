# Port the server listens on. Railway sets this automatically; only needed locally.
PORT=3001

# Postgres connection string, e.g. postgresql://user:password@host:5432/dbname
# On Railway, add a Postgres plugin and reference its DATABASE_URL.
DATABASE_URL=

# Set to "false" to disable SSL for local Postgres without SSL configured.
PGSSL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Refresh token for Google Drive, so re-auth isn't needed after a redeploy
# (the alternative, google-token.json on disk, is lost on ephemeral filesystems).
GOOGLE_REFRESH_TOKEN=

# Drive folder ID that project folders are created inside (Projects section).
# A direct subfolder here named GOOGLE_DRIVE_PROJECT_STAGING_FOLDER_NAME is the
# staging area: its subfolders are auto-created as Projects when the Projects
# page's "Sync from Drive" is used.
GOOGLE_DRIVE_PROJECTS_ROOT_ID=1CI1aOrDyaWzf8mwKi_QacnfhZrRZAvcT

# Name of the staging subfolder under GOOGLE_DRIVE_PROJECTS_ROOT_ID whose
# children become Projects. Defaults to "startup applications".
GOOGLE_DRIVE_PROJECT_STAGING_FOLDER_NAME=startup applications

# Drive folder ID that "Sync from Drive" reads from (Drive Files section).
# This is a pure mirror — everything found here becomes a browsable folder/file
# and is never linked to or merged into a Project, even if names happen to match.
GOOGLE_DRIVE_FILES_ROOT_ID=1cv0Mz_69aX4-7QJZphQ6_VOo16BGRWfd
